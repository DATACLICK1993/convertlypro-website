/* ─── Icon color classes per category ─────────────────────── */
const ICON_COLORS = {
  image:  'ico-blue',
  pdf:    'ico-red',
  doc:    'ico-amber',
  resize: 'ico-purple',
};

/* ─── Replace emoji icons with SVG icons ─────────────────── */
function applyIcons(){
  document.querySelectorAll('.tool-card[href]').forEach(card=>{
    const href=card.getAttribute('href')||'';
    // Extract tool id from href
    const match=href.match(/tools\/([^.]+)\.html/)||href.match(/([^/]+)\.html$/);
    if(!match)return;
    const id=match[1];
    const svg=ICONS[id];
    if(!svg)return;

    const icoEl=card.querySelector('.tc-ico');
    if(!icoEl)return;

    // Determine color class from current ico-* class or tool id
    const existingColor=[...icoEl.classList].find(c=>c.startsWith('ico-'));
    // Replace innerHTML with SVG
    icoEl.innerHTML=svg;
    // Remove font-size that was for emoji
    icoEl.style.fontSize='';
    // Add svg class for size control
    icoEl.classList.add('has-svg');
  });
}

/* ─── Sidebar related list icons ─────────────────────────── */
function applySidebarIcons(){
  document.querySelectorAll('.rel-list a').forEach(a=>{
    const href=a.getAttribute('href')||'';
    const match=href.match(/([^/]+)\.html$/);
    if(!match)return;
    const id=match[1];
    const svg=ICONS[id];
    if(!svg)return;
    const span=a.querySelector('span');
    if(span){span.innerHTML=svg;span.style.fontSize='';}
  });
}

document.addEventListener('DOMContentLoaded',()=>{
  applyIcons();
  applySidebarIcons();
});
